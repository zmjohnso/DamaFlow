{
  "name": "damaflow-init",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint .",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "forceExit": true,
